script:post-response {
  const body = res.body.data;
  const isSuccess = res.body.success
    if (isSuccess && body.accessToken) {
      bru.setEnvVar("accessToken", body.accessToken);
      bru.setEnvVar("refreshToken", body.refreshToken);
    }
}
