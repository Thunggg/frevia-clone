meta {
  name: Login
  type: http
  seq: 3
}

post {
  url: {{baseUrl}}/auth/login
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "email": "seller1@gmail.com",
    "password": "123456"
  }
}

script:post-response {
  const body = res.body;
    if (body.accessToken) {
      bru.setEnvVar("accessToken", body.accessToken);
      bru.setEnvVar("refreshToken", body.refreshToken);
    }
}
