meta {
  name: Change Job Status
  type: http
  seq: 5
}

patch {
  url: {{baseUrl}}/manage-jobs/{{jobId}}/status
  body: json
  auth: bearer
}

vars:pre-request {
  jobId: 1
}

headers {
  Content-Type: application/json
}

auth:bearer {
  token: {{accessToken}}
}

body:json {
  {
    "status": "OPEN"
  }
}
