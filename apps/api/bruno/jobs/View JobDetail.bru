meta {
  name: View Job Detail
  type: http
  seq: 2
}

get {
  url: {{baseUrl}}/jobs/{{slug}}
  body: none
  auth: none
}

headers {
  Accept: application/json
}

vars:pre-request {
  jobId: '''
    private createSlug(title: string, id: number) {
        return `${this.slugify(title)}-${id}`;
    }
  '''
  slug: e-commerce-website
}
